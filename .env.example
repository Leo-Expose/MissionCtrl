# MissionCtrl Environment Variables
# Copy this file to `.env` and fill in your values.
#
# These variables configure the **LLM client** used by `client.py` / `inference.py`
# (OpenAI-compatible `API_BASE_URL` + `MODEL_NAME` + `HF_TOKEN` as api_key).
# They are NOT read by the FastAPI server under `server/` unless you wire that yourself.

# --- Hugging Face router (matches README defaults for baseline eval) ---
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=openai/gpt-oss-120b
HF_TOKEN=hf_xxxxx

# To evaluate the same base you train with Unsloth (train.py default), point inference
# at a stack that serves that model id, e.g.:
# MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct

# --- Hugging Face dedicated Inference Endpoint (OpenAI-compatible + optional native fallback) ---
# Paste the endpoint URL from the Hub; if it has no `/v1` suffix, inference.py appends it.
# API_BASE_URL=https://YOUR_ID.region.gcp.endpoints.huggingface.cloud
# MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
# HF_TOKEN=hf_xxxxx
# If chat completions are unavailable but classic `inputs` generation works:
# MISSIONCTRL_HF_LLM_STRATEGY=native_only

# --- Groq (alternative OpenAI-compatible host) ---
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# HF_TOKEN=gsk_xxxxx

# Optional: override environment server URL (default: http://localhost:7860)
# ENV_BASE_URL=http://localhost:7860

# Optional: LLM judge API keys (for live demo mode)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# Optional: train.py (Colab / shell — not read automatically from this file)
# Default fast canary (Qwen2.5 0.5B Instruct); override for larger hubs:
# MISSIONCTRL_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
# MISSIONCTRL_MODEL_NAME=unsloth/Llama-3.2-3B-Instruct
# MISSIONCTRL_MODEL_NAME=unsloth/Meta-Llama-3.1-8B-Instruct-bnb-4bit
# MISSIONCTRL_LORA_RANK=16
# Phase-1 flat-reward early stop (default off in train.py; set to 1 to re-enable Kaggle shortcut):
# MISSIONCTRL_EARLY_STOP_PHASE1=0
# MISSIONCTRL_EARLY_STOP_MIN_STEPS=75
# GRPO speed (defaults: completion 80 tok, LR 2.5e-5, GRPO temp 0.55; 10 eval eps):
# MISSIONCTRL_LEARNING_RATE=2.5e-5
# MISSIONCTRL_GRPO_TEMPERATURE=0.55
# MISSIONCTRL_COMPLETION_MAX_TOKENS=80
# Curriculum: default off — each phase runs once; post-phase eval does not block or repeat.
# MISSIONCTRL_CURRICULUM_GATE=0
# Set to 1 to repeat phases until min_reward or max attempts (see train.py MAX_PHASE_REPEATS).
# MISSIONCTRL_CURRICULUM_GATE=1
# GRPO GenerationConfig merge into GRPOConfig (default off; avoids Transformers 5.5+ merge warnings):
# MISSIONCTRL_USE_GRPO_GENERATION_CONFIG=0
# Legacy: force merge if you relied on old default (equivalent to former SKIP=0):
# MISSIONCTRL_SKIP_GRPO_GENERATION_CONFIG=0
# Skip merge explicitly (redundant with default): MISSIONCTRL_SKIP_GRPO_GENERATION_CONFIG=1
# MISSIONCTRL_REPORT_TO=none
# MISSIONCTRL_SAVE_STEPS=200
# MISSIONCTRL_EVAL_EPISODES=10
# MISSIONCTRL_REWARD_THREADS=4
# MISSIONCTRL_SKIP_BASELINE=0
