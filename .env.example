# MissionCtrl Environment Variables
# Copy this file to .env and fill in your values.

# --- Hugging Face (Default) ---
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=openai/gpt-oss-120b
# HF_TOKEN=hf_xxxxx

# --- Groq ---
API_BASE_URL=https://api.groq.com/openai/v1
MODEL_NAME=llama-3.3-70b-versatile
HF_TOKEN=gsk_xxxxx

# Optional: override environment server URL (default: http://localhost:8000)
# ENV_BASE_URL=http://localhost:8000

# Optional: LLM judge API keys (for live demo mode)
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx

# Optional: train.py (Colab / shell — not read automatically from this file)
# MISSIONCTRL_LORA_RANK=16
# MISSIONCTRL_EARLY_STOP_PHASE1=1
# MISSIONCTRL_EARLY_STOP_MIN_STEPS=75
